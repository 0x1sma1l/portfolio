{
	"name": "portfolio",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "npm run content:check && vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync",
		"check": "npm run content:check && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"content:check": "node scripts/validate-content.mjs",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint ."
	},
	"devDependencies": {
		"@eslint/compat": "^1.2.5",
		"@eslint/js": "^9.18.0",
		"@sveltejs/adapter-netlify": "^6.0.4",
		"@sveltejs/kit": "^2.70.1",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"eslint": "^9.18.0",
		"eslint-config-prettier": "^10.0.1",
		"eslint-plugin-svelte": "^3.0.0",
		"globals": "^16.0.0",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.3.3",
		"svelte": "^5.56.6",
		"svelte-check": "^4.0.0",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.20.0",
		"vite": "^8.1.5"
	},
	"dependencies": {
		"gray-matter": "^4.0.3",
		"mdsvex": "^0.12.8",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-pretty-code": "^0.14.4",
		"rehype-slug": "^6.0.0",
		"remark-gfm": "^4.0.1",
		"shiki": "^4.3.1",
		"zod": "^4.4.3"
	}
}
